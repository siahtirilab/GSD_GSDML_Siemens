F_Ext_User_Prm_Data_Ref(2)      = 1           
F_Ext_User_Prm_Data_Ref(4)      = 2             ;F-CHECK-SEQ. NO
F_Ext_User_Prm_Data_Ref(4)      = 3             ;F-SIL
F_Ext_User_Prm_Data_Ref(4)      = 4             ;F-CRC_LENGTH
F_Ext_User_Prm_Data_Ref(5)      = 5             ;F-VERSION-ID
F_Ext_User_Prm_Data_Ref(6)      = 6             ;F-Source-Adr
