Procedure Hauptmenu
  ;; Hauptmenü der Installation

If [CurrentCountryCode] = 49
  GetMenuChoice [MenuColor] @xy(Center,8) UseHeader " Hauptmenü "
    Gesamtinstallation von LEMOC2 V3.4
     ;LEMOC2 wird vollständig installiert. Dazu werden etwa 5 MByte freier
     ;Speicher auf Ihrer Festplatte benötigt. Wenn eine ältere Version
     ;vorhanden ist, erfolgt ein Update auf die neue Version.
     ;LEMOC2 wird in den Sprachen Deutsch, Englisch und Französisch installiert.
    Anzeige zusätzlicher Informationen zu LEMOC2
     ;Es wird die Datei LIESDAS.TXT von LEMOC2 angezeigt.
    Beenden der Installation
     ;Das Installationsprogramm wird beendet.
  EndGetMenuChoice
Endif

If [CurrentCountryCode] = 44
  GetMenuChoice [MenuColor] @xy(Center,8) UseHeader " Main menu "
    Total installation of LEMOC2 V3.4
     ;LEMOC2 is completely installed. About 5 Mbyte of free memory of your 
     ;hard disk are required for this installation. When using an older version
     ;it will be updated.
     ;LEMOC2 is available in German, English and French.
    Display of additional information about LEMOC2
     ;The file README.TXT of LEMOC2 is displayed.
    End of the installation
     ;The installation program will be exited.
  EndGetMenuChoice
Endif

If [CurrentCountryCode] = 33
  GetMenuChoice [MenuColor] @xy(Center,8) UseHeader " menu principal "
    Installation complŖte de LEMOC2 V3.4
     ;La version complŖte de LEMOC2 va łtre installée. L'espace mémoire nécessaire  
     ;sur votre disque dur est de 5 Mo. 
     ;LEMOC2 sera installé en allemand, en anglais et en franćais.
    Informations supplémentaires concernant LEMOC2
     ;Le fichier LISEZMOI de LEMOC2 sera affiché.
    Quittez l'installation
     ;Le programme d'installation sera interrompu.
  EndGetMenuChoice
Endif

ClearScreen
  InCase Choice is
    =1: [LM2GesamtFlag]   := YESCharacter
    =2: [LM2TextAnzFlag]  := YESCharacter
    =3: [EndeInstallFlag] := YESCharacter
  EndInCase

EndProcedure


Procedure FirstDialog
  ;; Infobildschirm vor dem Beginn der Installation
  if [CurrentCountryCode] = 49
    Dialog @xy(Center,2) [DialogColor] 76 UseHeader " [Product] "

      LEMOC2 ist ein Programm zur Parametrierung von LENZE Antriebs-
      reglern und Automatisierungsbaugruppen. Der Datenaustausch
      zwischen PC und Antrieb erfolgt über eine serielle Schnittstelle.

      Das Programm steht in den Sprachen Deutsch, Englisch und Französisch
      zur Verfügung.

      Bei der Installation beachten Sie bitte die Hinweise zu den
      jeweiligen Installationsschritten.

      Für weitere Informationen stehen wir Ihnen gern zur Verfügung.

      [CompanyName]
      [CompanyPostfach]
      [CompanyOrt]
      [CompanyTelefon]

    EndDialog
  endif

  if [CurrentCountryCode] = 44
    Dialog @xy(Center,2) [DialogColor] 76 UseHeader " [Product] "

      LEMOC2 is a program for the parameterization of LENZE drive
      controller and automation modules. The data is exchanged between
      PC and drive via a serial interface.

      The program is available in German, English and French.

      Please take note of the information on different installation steps.

      Please do not hesitate to contact us for further information.

      [CompanyName]
      [CompanyPostfach]
      [CompanyOrt]
      [CompanyTelefon]

    EndDialog
  endif

  if [CurrentCountryCode] = 33
    Dialog @xy(Center,2) [DialogColor] 76 UseHeader " [Product] "

      LEMOC2 est un programme permettant le paramétrage des variateurs
      et modules d'automatisme LENZE. L'échange de données entre PC et
      variateurs se fait via la liaison série.

      Le programme peut łtre utilisé en allemand, en anglais ou en 
      franćais.
      
      Lors de l'installation, veuillez prendre connaissance des 
      différents messages apparaissant ģ chaque pas d'installation.
      
      Nous sommes ģ votre entiŖre disposition, si vous souhaitez obtenir
      des informations supplémentaires.

      [CompanyName]
      [CompanyPostfach]
      [CompanyOrt]
      [CompanyTelefon]

    EndDialog
  endif
EndProcedure


Procedure MakeLemoc2Pfad
  ;; Bestimmen des Installationsverzeichnisses
  If [LEMOC2Directory] = BlankString
    [InstallationDirectory] := [DefaultInstallationDirectory]
  Else
    [InstallationDirectory] := [LEMOC2Directory]
  Endif
  DetermineInstallationDrive RequireFixed AllowNetwork
  DetermineInstallationDirectory RequireFixed AllowNetwork
  [LEMOC2Directory] := [InstallationDirectory]
  ;; Voreinstellungen der Pfade für die Installation der Filegruppen
  [Dir1] := [InstallationDirectory]\bin
  [Dir2] := [InstallationDirectory]\data
  [Dir3] := [InstallationDirectory]\pdb\049
  [Dir4] := [InstallationDirectory]\pdb\044
  [Dir5] := [InstallationDirectory]\pdb\033
EndProcedure

Procedure LEMOC2Exist
  ;; Test, ob Lemoc2 bereits vorhanden ist
  [LM2InvVersExist] := NoCharacter
  [LM2OldVersExist] := NoCharacter
  [LM2IdentVersExist] := NoCharacter
  [LM2NewVersExist] := NoCharacter
  [NewDir] := NoCharacter

  if (FileExists [Dir1]\[LEMOC2ver]) .or. (FileExists [Dir1]\[LEMOC2exe])
    [String2] := BlankString
    [String3] := BlankString
    [String4] := BlankString
    [String5] := BlankString
    [String6] := BlankString
    if FileExists [Dir1]\[LEMOC2ver]
      ExamineTextFile [Dir1]\[LEMOC2ver]
        [String2] := SettingFor Version
        [String3] := SettingFor LM2ID
        [String4] := SettingFor Status
        [String5] := SettingFor InstallationDate
        [String6] := SettingFor InstallationTime
      ForgetTextFile
      If [String4] <> Installation OK
        [LM2InvVersExist] := YesCharacter
      Endif
      If [String2] < 3.3
        [LM2OldVersExist] := YesCharacter
      Endif
      If [String2] = 3.3
        [LM2IdentVersExist] := YesCharacter
      Endif
      If [String2] > 3.3
        [LM2NewVersExist] := YesCharacter
      Endif
    Else
      [LM2InvVersExist] := YesCharacter
      [LM2OldVersExist] := YesCharacter
    Endif

    if [LM2InvVersExist]
      Do DialogInvalidVersion
      Goto EndeLM2Exist
    Endif
    if [LM2OldVersExist]
      Do DialogOldVersion
      Goto EndeLM2Exist
    Endif
    if [LM2NewVersExist]
      Do DialogNewVersion
      Goto EndeLM2Exist
    Endif
    if [LM2IdentVersExist]
      Do DialogIdentVersion
      Goto EndeLM2Exist
    Endif
  Endif
:EndeLM2Exist
EndProcedure

