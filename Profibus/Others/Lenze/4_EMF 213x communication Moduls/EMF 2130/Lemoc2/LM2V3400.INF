Procedure LEMOC2Installation
  ;; LEMOC2 wird installiert, Gesamtinstallation, alle Sprachen und PDB
  ;; Pfad für Lemoc2 Installation
  [PDBFuFlag]       := YesCharacter
  [PDBSrFlag]       := YesCharacter
  [PDBServoFlag]    := YesCharacter
  [PDBOptFlag]      := YesCharacter
  [PDBBusFlag]      := YesCharacter
  [LM2GermanFlag]   := YesCharacter
  [LM2EnglischFlag] := YesCharacter
  [LM2FranzFlag]    := YesCharacter
:BeginLM2Inst
  Do MakeLemoc2Pfad
  ;; Test, ob Lemoc2 bereits vorhanden ist
  Do LEMOC2Exist              ;; Testen der Existenz und der Version
  [String1]    := noinquiry
  if [NewDir]
    ;; Benutzer will neues Verzeichnis wählen
    GoTo BeginLM2Inst
  endif
  [LM2InstAbbruchFlag] := NoCharacter

  Do LM2BinInstall
  If [LM2InstAbbruchFlag] .or. ([BeginnInstallFlag] = NoCharacter)
    Goto EndeLM2Installation
  Endif
  Do LM2InstallPDB
  If [LM2InstAbbruchFlag]
    Goto EndeLM2Installation
  Endif
  [LM2InstallStatusOK] := YesCharacter
  Do WriteInstallStatus
  Do LM2InstallOkDialog
  SetCompletionStatusTo finished

:EndeLM2Installation
  If [LM2InstAbbruchFlag]
    ;; Kennung, das Installation nicht OK wird in LEMOC2.VER eingetragen
    [LM2InstallStatusOK] := NoCharacter
    Do WriteInstallStatus
  Endif
EndProcedure

Procedure LEMOC2TeilInstallation
  ;; Installation von ausgewählten Komponenten von LEMOC2
  [PDBFuFlag]       := YesCharacter
  [PDBSrFlag]       := NoCharacter
  [PDBServoFlag]    := NoCharacter
  [PDBOptFlag]      := NoCharacter
  [PDBBusFlag]      := NoCharacter
  [LM2GermanFlag]   := YesCharacter
  [LM2EnglischFlag] := YesCharacter
  [LM2FranzFlag]    := YesCharacter

:BeginnLM2TeilInstallation
  SetAllowEscape on
  SetBottomLineTo [BottomLine1]
  LetButton <F2>  Do nothing
  LetButton <F10> Do nothing
  LetButton <F2>  Do NullProcedure
  LetButton <F10> Do NullProcedure

  If [CurrentCountryCode] = 49
    Dialog Multiple @xy(Center,Center) [DialogColor] UseHeader "Teilinstallation von LEMOC2"
      WriteText "Bitte wählen Sie die zu installierenden LEMOC2 " @xy(2,1)
      WriteText "Gerätebeschreibungen aus."                       @xy(2,2)

      WriteText "Zu installierende Gerätebeschreibungen:"      @xy(2,4)
      WriteText "Frequenzumrichter 8100, 8200, 8600         "  @xy(2,6) [DialogColor2]
      WriteText "Stromrichter 4900                          "  @xy(2,7) [DialogColor2]
      WriteText "Servo-Antriebe 9200, 9300                  "  @xy(2,8) [DialogColor2]
      WriteText "Automatisierungsbaugruppen 2211, 2212      "  @xy(2,9) [DialogColor2]
      WriteText "Feldbusbaugruppen 2110, 2130               "  @xy(2,10) [DialogColor2]

      CheckBox  [PDBFuFlag]       @xy(45,6)   [DialogColor2]
      CheckBox  [PDBSrFlag]       @xy(45,7)   [DialogColor2]
      CheckBox  [PDBServoFlag]    @xy(45,8)   [DialogColor2]
      CheckBox  [PDBOptFlag]      @xy(45,9)   [DialogColor2]
      CheckBox  [PDBBusFlag]      @xy(45,10)  [DialogColor2]








      "                                                "
    EndDialog
  Endif

  If [CurrentCountryCode] = 44
    Dialog Multiple @xy(Center,Center) [DialogColor] UseHeader "Partial installation of LEMOC2"
      WriteText "Please select the controller descriptions " @xy(2,1)
      WriteText "of LEMOC2 to be installed."                 @xy(2,2)

      WriteText "Controller descriptions to be installed:   "  @xy(2,4)
      WriteText "8100, 8200, 8600 frequency inverter        "  @xy(2,6) [DialogColor2]
      WriteText "4900 drive controller                      "  @xy(2,7) [DialogColor2]
      WriteText "9200, 9300 servo drive                     "  @xy(2,8) [DialogColor2]
      WriteText "Automation modules 2211, 2212              "  @xy(2,9) [DialogColor2]
      WriteText "Field bus modules 2110, 2130               "  @xy(2,10) [DialogColor2]

      CheckBox  [PDBFuFlag]       @xy(45,6)   [DialogColor2]
      CheckBox  [PDBSrFlag]       @xy(45,7)   [DialogColor2]
      CheckBox  [PDBServoFlag]    @xy(45,8)   [DialogColor2]
      CheckBox  [PDBOptFlag]      @xy(45,9)   [DialogColor2]
      CheckBox  [PDBBusFlag]      @xy(45,10)  [DialogColor2]








      "                                                "
    EndDialog
  Endif

  If [CurrentCountryCode] = 33
    Dialog Multiple @xy(Center,Center) [DialogColor] UseHeader "Installation partielle de LEMOC2"
      WriteText "Veuillez sélectionner les fichiers         " @xy(2,1)
      WriteText "Type d'appareil ģ installer"                 @xy(2,2)

      WriteText "Fichiers Type d'appareil ģ installer:"       @xy(2,4)
      WriteText "Convert. de fréquences 8100, 8200, 8600    "  @xy(2,6) [DialogColor2]
      WriteText "Variateurs courant continu 4900            "  @xy(2,7) [DialogColor2]
      WriteText "Servovariateurs 9200, 9300                 "  @xy(2,8) [DialogColor2]
      WriteText "Modules d'automatisme 2211, 2212           "  @xy(2,9) [DialogColor2]
      WriteText "Modules bus de terrain 2110, 2130          "  @xy(2,10) [DialogColor2]

      CheckBox  [PDBFuFlag]       @xy(45,6)   [DialogColor2]
      CheckBox  [PDBSrFlag]       @xy(45,7)   [DialogColor2]
      CheckBox  [PDBServoFlag]    @xy(45,8)   [DialogColor2]
      CheckBox  [PDBOptFlag]      @xy(45,9)   [DialogColor2]
      CheckBox  [PDBBusFlag]      @xy(45,10)  [DialogColor2]








      "                                                "
    EndDialog
  Endif

  SetAllowEscape off
  SetBottomLineTo [BottomLine]
  LetButton <F2>  Do nothing
  LetButton <F10> Do nothing
  LetButton <F2>  Do SystemInfo
  LetButton <F10> Do EndeInstallationF10

  If Escaped
    ;; Abbruch der Auswahl, zurück zum Hauptmenü
    Goto TeilInstallationEnde
  Endif

  ;; Test, ob wenigstens eine Gruppe von PDB ausgewählt wurde
  If [PDBFuFlag] .or. [PDBSrFlag] .or. [PDBServoFlag] .or. [PDBOptFlag] .or. [PDBBusFlag]
    ;; Installation der Grundgeräte PDB ist ausgeführt
  Else
    ;; keine PDB ist ausgewählt worden, Auswahl wird neu aufgerufen
    Do DialogKeinePDBAuswahl
    Goto BeginnLM2TeilInstallation
  Endif

  ;; Test, ob Lemoc2 in dem auszuwählenden Verzeichnis bereits existiert
:LM2TeilInstallBinPfad
  Do MakeLemoc2Pfad
  Do LEMOC2Exist                ;; Testen der Version
  [String1]    := noinquiry
  if [NewDir]
    ;; Benutzer will neues Verzeichnis wählen
    GoTo LM2TeilInstallBinPfad
  endif
  ;; Installation von LM2 und PDB
  [LM2InstAbbruchFlag] := NoCharacter
  [BeginnInstallFlag] := YesCharacter
  If [LM2IdentVersExist] .and. ([LM2InvVersExist] = NoCharacter)
  Else
    ;; Bin Teil wird nur ausgeführt, wenn keine identische Version
    ;; oder unvollständige Installation
    Do LM2BinInstall
  Endif
  If [LM2InstAbbruchFlag] .or. ([BeginnInstallFlag] = NoCharacter)
    Goto TeilInstallationEnde
  Endif
  Do LM2InstallPDB
  If [LM2InstAbbruchFlag]
    Goto TeilInstallationEnde
  Endif
  [LM2InstallStatusOK] := YesCharacter
  Do WriteInstallStatus
  Do LM2InstallOkDialog
  SetCompletionStatusTo finished

:TeilInstallationEnde
  If [LM2InstAbbruchFlag]
    [LM2InstallStatusOK] := NoCharacter
    Do WriteInstallStatus
  Endif
EndProcedure

Procedure LM2InstallPDB
  ;; Installation von PDB Dateien, Installation erfolgt in Abhängikeit
  ;; von den PDB-Flags

  InstallSeries lm2v340b.pvl

  If [PDBSrFlag]
    Do PDBAllInstall
  Endif
  GetQuedFiles OnePerLine
  If QueSize > 0
    [LM2InstAbbruchFlag] := YesCharacter
    UnQueAllFiles
  Endif

EndProcedure

Procedure PDBAllInstall
  ;; Installation von PDB 
  QueFileGroup 149 [Dir3] [String1]
  If [LM2EnglischFlag]
    QueFileGroup 144 [Dir4] [String1]
  Endif
EndProcedure

Procedure LM2BinInstall
  ;; Das Programm LEMOC2 wird installiert, ohne PDB
  ;; Abfrage, ob Installation wirklich begonnen werden soll
  Do BeginInstallationDialog
  If [BeginnInstallFlag] = NoCharacter
;;  [LM2InstAbbruchFlag] := YesCharacter
    Goto EndeLM2BinInstall
  Endif

  InstallSeries lm2v340a.pvl

  SetCompletionStatusTo unfinished
  ;; Installation der einzelnen Files
  QueFiles [Dir1] [String1]
    lemoc2.ver
    egavga.bgi
    lm2.exe
    lm2spr01.cnf
    lm2*.049
    netlist.*
  EndQueFiles
  If [LM2EnglischFlag]
    QueFileGroup 944 [Dir1] [String1]
  Endif
  If [LM2FranzFlag]
    QueFileGroup 933 [Dir1] [String1]
  Endif
  GetQuedFiles OnePerLine
  If QueSize > 0
    [LM2InstAbbruchFlag] := YesCharacter
    UnQueAllFiles
    Goto EndeLM2BinInstall
  Endif

  OpenCopyWindow [DialogColor]
  CopyFiles from [InstallFromDirectory] to [InstallationDirectory]
    liesdas.txt
    readme.txt
    lisezmoi.txt
  EndCopyFiles
  CloseCopyWindow

  CreateDirectoryIfNecessary [Dir2]

  ;; Startsprache ermitteln
  Do LM2SelectStartLanguage
  Do WriteSpracheToConfigDatei
  SetCompletionStatusTo finished
:EndeLM2BinInstall
EndProcedure

Procedure WriteSpracheToConfigDatei
  ;; Standardkonfigurationsfile wird in lm2conf.cnf kopiert. In
  ;; Abhängigkeit von der Startsprache wird die Sprachkennung modifiziert
  CopyFiles from [InstallFromDirectory] to [Dir1] quietly
    lm2conf.049 as lm2conf.cnf
  EndCopyFiles
  If [LM2StartLanguage] = 44
    ModifyTextFile [Dir1]\lm2conf.cnf NoBackup
      AddOrChangeLineWith (00104;,,) as "00104;044" At Beginning
    EndModifyTextFile
  Endif
  If [LM2StartLanguage] = 33
    ModifyTextFile [Dir1]\lm2conf.cnf NoBackup
      AddOrChangeLineWith (00104;,,) as "00104;033" At Beginning
    EndModifyTextFile
  Endif
EndProcedure

Procedure WriteInstallStatus
  ;; in der Datei Lemoc2.ver wird der Installationsstatus in
  ;; Abhängigkeit von dem LM2InstallStatusOk auf Installation Ok
  ;; oder Not Installt gesetzt
  If [LM2InstallStatusOk]
    [String2] := SystemDate
    [String3] := SystemTime
    [String4] := InstallationDate=[String2]
    [String5] := InstallationTime=[String3]
    ModifyTextFile [Dir1]\lemoc2.ver NoBackup
      InSection [INSTALLATION]
      AddOrChangeLineWith (Status,,) as "Status=Installation OK" at End
      AddOrChangeLineWith (InstallationDate,,) as "[String4]" at End
      AddOrChangeLineWith (InstallationTime,,) as "[String5]" at End
    EndModifyTextFile
  Else
    ModifyTextFile [Dir1]\lemoc2.ver NoBackup
      InSection [INSTALLATION]
      AddOrChangeLineWith (Status,,) as "Status=Not Installed" at End
    EndModifyTextFile
  Endif
EndProcedure

Procedure AbbruchESC
  ;; Kennung setzen, daß ESC benutzt wurde
  [AbortESCFlag] := YesCharacter
EndProcedure

Procedure LM2InstallOkDialog
  ;; Anzeige, daß Installation OK
  If [CurrentCountryCode] = 49
    Dialog PressAKey [DialogColor1]
      LEMOC2 wurde erfolgreich installiert !

      Nach dem Verlassen des Installationsprogramms können Sie LEMOC2
      durch folgenden Aufruf starten:

      [Dir1]\lm2

    EndDialog
  Endif
  If [CurrentCountryCode] = 44
    Dialog PressAKey [DialogColor1]
      LEMOC2 has been installed successfully!

      After having exited the installation program, LEMOC2 can be started
      by means of the following command line:

      [Dir1]\lm2

    EndDialog
  Endif
  If [CurrentCountryCode] = 33
    Dialog PressAKey [DialogColor1]
      LEMOC2 a été parfaitement installé !

      AprŖs avoir quitté le programme d'installation, vous pouvez lancer
      LEMOC2 comme suit:

      [Dir1]\lm2

    EndDialog
  Endif
EndProcedure

Procedure DialogKeinePDBAuswahl
  ;; Dialog, daß keine PDB ausgewählt wurde bei der Teilinstallation
  If [CurrentCountryCode] = 49
    Dialog PressAKey [DialogColor1]
      Sie haben keine Gerätebeschreibungen zur Installation
      ausgewählt. Sie müssen mindestens eine Gruppe von
      Gerätebeschreibungen auswählen.
    EndDialog
  Endif
  If [CurrentCountryCode] = 44
    Dialog PressAKey [DialogColor1]
      You have not selected a controller description for the installation
      At least, you have to select a group of controller descriptions.
    EndDialog
  Endif
  If [CurrentCountryCode] = 33
    Dialog PressAKey [DialogColor1]
      Vous n'avez demandé l'installation d'aucun fichier Type d'appareil.
      Vous devez sélectionner au moins un fichier Type d'appareil.
    EndDialog
  Endif
EndProcedure

Procedure LEMOC2Readme
  ;; Anzeigen des Readme.txt von LEMOC2
  If [CurrentCountryCode] = 49
    BrowseFile [InstallFromDirectory]\liesdas.txt
  Endif
  If [CurrentCountryCode] = 44
    BrowseFile [InstallFromDirectory]\readme.txt
  Endif
  If [CurrentCountryCode] = 33
    BrowseFile [InstallFromDirectory]\lisezmoi.txt
  Endif
EndProcedure

Procedure EndeInstallation
  ;; Beenden des Installationsprogramms
  ClearScreen
  SoLong
EndProcedure

Procedure EndeInstallationF10
  ;; Beenden der Installation über Taste F10
  If CompletionStatus = Finished
    Goto HauptmenuDataReset
  else
    If [CurrentCountryCode] = 49
      Dialog [YesOrNo1] [DialogColor1]
        Die Installation ist nicht komplett.
        Wollen Sie die Installation wirklich abbrechen ?
      EndDialog
    Endif
    If [CurrentCountryCode] = 44
      Dialog [YesOrNo1] [DialogColor1]
        The program is not completely installed yet.
        Do you really want to abort the installation ?
      EndDialog
    Endif
    If [CurrentCountryCode] = 33
      Dialog [YesOrNo1] [DialogColor1]
        L'installation n'est pas complŖte.
        Souhaitez-vous réellement abandonner l'installation ?
      EndDialog
    Endif

    if [YesOrNo1] = NoCharacter
      UnQueAllFiles
      GoTo HauptmenuDataReset
    else
      SetCompletionStatusTo finished
      UnQueAllFiles
      Do EndeInstallation
    endif
  endif
EndProcedure

Procedure CheckInstallLanguage
  ;; Ermitteln der Installationssprache
  [CurrentCountryCode] := CountryCode
  ;; Test, ob für den aktuellen ContryCode auch ein LRM File vorhanden ist
  [Number1] := [CurrentCountryCode]
  [YesOrNo1] := NoCharacter
  InCase [Number1] is
    =49: Speak [InstallFromDirectory]\german.lrm
         [YesOrNo1] := YesCharacter
    =44: Speak [InstallFromDirectory]\english.lrm
         [YesOrNo1] := YesCharacter
    =33: Speak [InstallFromDirectory]\french.lrm
         [YesOrNo1] := YesCharacter
  EndInCase
  If [YesOrNo1] = NoCHaracter
    ;; Wenn CountryCode nicht gefunden, wird Default benutzt
    [CurrentCountryCode] := [DefaultCountryCode]
    Speak [InstallFromDirectory]\german.lrm
  Endif

  GetMenuChoice [MenuColor] @xy(Center,8) UseHeader " Sprache/Language..... "
    Deutsch
      ; Bitte wählen Sie eine Sprache für das Installationsprogramm.
    Englisch
      ; Please select a language for the installation program.
    Französisch
      ; Veuillez sélectionner la langue du programme d'installation.
  EndGetMenuChoice

  InCase Choice is
    =1: [CurrentCountryCode]     := 49
        Speak [InstallFromDirectory]\german.lrm
    =2: [CurrentCountryCode]     := 44
        Speak [InstallFromDirectory]\english.lrm
    =3: [CurrentCountryCode]     := 33
        Speak [InstallFromDirectory]\french.lrm
  EndInCase
EndProcedure

Procedure LM2SelectStartLanguage
  ;; Ermitteln der Sprache mit der Lemoc2 gestartet werden soll
:BeginnSelectStartLanguage
  GetMenuChoice [MenuColor] @xy(Center,8)
    Deutsch
      ; Bitte wählen Sie die Sprache in der LEMOC2 gestartet werden soll.
      ; Please select the language in which LEMOC2 is to be started
      ; Veuillez sélectionner la langue dans laquelle sera démarré LEMOC2.
    Englisch
      ; Bitte wählen Sie die Sprache in der LEMOC2 gestartet werden soll.
      ; Please select the language in which LEMOC2 is to be started
      ; Veuillez sélectionner la langue dans laquelle sera démarré LEMOC2.
    Französisch
      ; Bitte wählen Sie die Sprache in der LEMOC2 gestartet werden soll.
      ; Please select the language in which LEMOC2 is to be started
      ; Veuillez sélectionner la langue dans laquelle sera démarré LEMOC2.
  EndGetMenuChoice

  InCase Choice is
    =1: [LM2StartLanguage] := 49
    =2: [LM2StartLanguage] := 44
        If [LM2EnglischFlag] = NoCharacter
        ;; Englisch ist nicht installiert
          Do NoStartLanguageDialog
          [LM2StartLanguage] := 49
          GoTo BeginnSelectStartLanguage
        Endif
    =3: [LM2StartLanguage] := 33
        If [LM2FranzFlag] = NoCharacter
        ;; Französich ist nicht installiert
          Do NoStartLanguageDialog
          [LM2StartLanguage] := 49
          GoTo BeginnSelectStartLanguage
        Endif
  EndInCase
EndProcedure

Procedure NoStartLanguageDialog
  ;; Anzeige, daß ausgewählte Startsprache nicht vorhanden
  If [CurrentCountryCode] = 44
    Dialog PressAKey [DialogColor1]
      LEMOC2 is not installed in the selected language.
      Please select another language to start LEMOC2
      and then install LEMOC2 in the selected language
    EndDialog
  Endif
  If [CurrentCountryCode] = 33
    Dialog PressAKey [DialogColor1]
      LEMOC2 n'a pas été installé dans la langue sélectionnée.
      Veuillez sélectionner une autre langue pour le démarrage
      de LEMOC2 et veuillez installer ultérieurement LEMOC2 dans
      la langue sélectionnée.
    EndDialog
  Endif
EndProcedure


Procedure BeginInstallationDialog
  If [CurrentCountryCode] = 49
    Dialog [BeginnInstallFlag] [DialogColor1]
      Die Dateien werden im Verzeichnis

      [InstallationDirectory]

      installiert.
      Wollen Sie die Installation beginnen ?
    EndDialog
  Endif
  If [CurrentCountryCode] = 44
    Dialog [BeginnInstallFlag] [DialogColor1]
      The files will be installed in the directory

      [InstallationDirectory]

      Do you want to start the installation ?
    EndDialog
  Endif
  If [CurrentCountryCode] = 33
    Dialog [BeginnInstallFlag] [DialogColor1]
      Les fichiers seront installés dans le répertoire

      [InstallationDirectory].

      Souhaitez-vous démarrer l'installation ?
    EndDialog
  Endif
EndProcedure

Procedure AbbruchESC
  ;; Kennung setzen, daß ESC benutzt wurde
  [AbortESCFlag] := YesCharacter
EndProcedure

Procedure NullProcedure
  ;; Die Funktion tut nichts und wird benutzt zum Abfangen von F-Tasten
  ;; Alt+X,  Ctrl+X
EndProcedure


Procedure SystemInfo
  If [InstallationDirectory] <> BlankString
    [InstallationDriveSummary] := InstallationDrive (FreeSpaceOnDrive InstallationDrive bytes frei)
  else
    [InstallationDriveSummary] := (nicht selektiert)
  EndIf
  If [CurrentCountryCode] = 49
    Dialog PressAKey [DialogColor] UseHeader " System-Informationen "
      Betriebssystem Version:   [OSVersionSummary]
      CPU Typ:                  [CPUTypeSummary]
      Display Adapter:          [DisplayAdapterSummary]
      Math. Coprocessor:        [MathCoprocessorStatus]
      Konvent. Speicher:        [SystemMemorySummary]
      max. XMS Speicher:        ExtendedMemoryPresentK
      verfügbarer XMS Speicher: XMSMemoryAvailableK
      Netzwerk:                 [NetworkActive]
      Serielle Schnittstellen:  [COMPortSummary]
      Parallele Schnittstellen: [LPTSummary]


      Installations Laufwerk:   [InstallationDriveSummary]
      Freier Arbeitsspeicher:   FreeRunMemory byte
    EndDialog
  Endif
  If [CurrentCountryCode] = 44
    Dialog PressAKey [DialogColor] UseHeader " System-Informationen "
      Operating system version: [OSVersionSummary]
      CPU type:                 [CPUTypeSummary]
      Display adapter:          [DisplayAdapterSummary]
      Math. coprocessor:        [MathCoprocessorStatus]
      Convent. memory:          [SystemMemorySummary]
      max. XMS memory:          ExtendedMemoryPresentK
      Available XMS memory:     XMSMemoryAvailableK
      Network:                  [NetworkActive]
      Serial interfaces:        [COMPortSummary]
      Parallel interfaces:      [LPTSummary]


      Installation drive:       [InstallationDriveSummary]
      Free user memory:         FreeRunMemory byte
    EndDialog
  Endif
  If [CurrentCountryCode] = 33
    Dialog PressAKey [DialogColor] UseHeader " System-Informationen "
      Betriebssystem Version:   [OSVersionSummary]
      CPU Typ:                  [CPUTypeSummary]
      Display Adapter:          [DisplayAdapterSummary]
      Math. Coprocessor:        [MathCoprocessorStatus]
      Konvent. Speicher:        [SystemMemorySummary]
      max. XMS Speicher:        ExtendedMemoryPresentK
      verfügbarer XMS Speicher: XMSMemoryAvailableK
      Netzwerk:                 [NetworkActive]
      Serielle Schnittstellen:  [COMPortSummary]
      Parallele Schnittstellen: [LPTSummary]


      Installations Laufwerk:   [InstallationDriveSummary]
      Freier Arbeitsspeicher:   FreeRunMemory byte
    EndDialog
  Endif
EndProcedure

Procedure PrepareSystemReport
  [InsufficientSystem] := NoCharacter
  [OSVersionSummary] := OSVersion
  [SystemMemorySummary] := MainMemoryK
  If 808X .or. 8018X
    [CPUTypeSummary] := 808x (nicht kompatibel mit LEMOC2)
    [InsufficientSystem] := YesCharacter
  EndIf
  If 80286
    [CPUTypeSummary] := 80286
  EndIf
  If 80386
    [CPUTypeSummary] := 80386
  EndIf
  If 80486
    [CPUTypeSummary] := 80486
  EndIf
  If [CPUTypeSummary] = BlankString
    [CPUTypeSummary] := >80486
  EndIf
  If MicroChannel
    [CPUTypeSummary] := [CPUTypeSummary] (MicroChannel Architektur)
  else
    [CPUTypeSummary] := [CPUTypeSummary] (ISA or EISA Architektur)
  EndIf
  If CGA
    [DisplayAdapterSummary] := CGA (nicht kompatible mit LEMOC2)
    [InsufficientSystem] := YesCharacter
  EndIf
  If MDA
    [DisplayAdapterSummary] := MDA
  EndIf
  If EGA
    [DisplayAdapterSummary] := EGA
  EndIf
  If VGA
    [DisplayAdapterSummary] := VGA
  EndIf
  If HGC
    [DisplayAdapterSummary] := HGC
  EndIf
  If HGCPlus
    [DisplayAdapterSummary] := HGC Plus
  EndIf
  If Network
    [NetworkActive] := Netzwerk vorhanden
  else
    [NetworkActive] := kein Netzwerk
  EndIf
  If NovellLoaded
    [NetworkActive] := Novell [NetworkActive]
  EndIf
  If MathCoprocessorPresent
    [MathCoprocessorStatus] := vorhanden
  EndIf
  [Number1] := 1
  [Number2] := 0
  While [Number1] < 5
    if COMPortPresent [Number1]
      IncrementNumber [Number2]
    endif
    IncrementNumber [Number1]
  EndWhile
  if [Number2] = 0
    [COMPortSummary] := [Number2] (nicht kompatibel mit LEMOC2)
    [InsufficientSystem] := YesCharacter
  else
    [COMPortSummary] := [Number2]
  endif
  [Number1] := 1
  [Number2] := 0
  While [Number1] < 4
    if PrinterPortPresent [Number1]
      IncrementNumber [Number2]
    endif
    IncrementNumber [Number1]
  EndWhile
  if [Number2] = 0
    [LPTSummary] := [Number2] (nicht kompatibel mit LEMOC2)
    [InsufficientSystem] := YesCharacter
  else
    [LPTSummary] := [Number2]
  endif

EndProcedure
