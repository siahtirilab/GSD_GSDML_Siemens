;************* Prozessdaten mit Konsistenz **********
Module = "PZD( 1 W. Cons.)             " 0x70
EndModule
Module = "PZD( 2 W. Cons.)          " 0xF1
EndModule
Module = "PZD( 3 W. Cons.)          " 0xF2
EndModule
